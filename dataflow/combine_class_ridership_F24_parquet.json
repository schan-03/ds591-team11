{
	"name": "combine_class_ridership_F24_parquet",
	"properties": {
		"description": "Combine Fall 2024 Ridership data with Fall 2024 class schedule ",
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Json_Historical_MBTA",
						"type": "DatasetReference"
					},
					"name": "historicalmbtaf24"
				},
				{
					"dataset": {
						"referenceName": "CSV_finals_f24",
						"type": "DatasetReference"
					},
					"name": "finalsf24"
				},
				{
					"dataset": {
						"referenceName": "CSV_bu_building_code",
						"type": "DatasetReference"
					},
					"name": "bubuildingcodes"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Parquet_historical_mbta",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "Parquet_finals24",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "Parquet_BU_BUILDING_CODE",
						"type": "DatasetReference"
					},
					"name": "sink3"
				}
			],
			"transformations": [
				{
					"name": "flatten1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "select4"
				}
			],
			"scriptLines": [
				"source(output(",
				"          type as string,",
				"          name as string,",
				"          crs as (type as string, properties as (name as string)),",
				"          features as (type as string, properties as (mode as string, season as string, route_id as string, route_name as string, dir_id as string, day_type_id as string, day_type_name as string, stop_name as string, parent_station as string, total_ons as integer, total_offs as integer, number_service_days as integer, hour_of_service as string, average_ons as integer, average_offs as integer, average_flow as integer, ObjectId as integer), geometry as string)[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'documentPerLine') ~> historicalmbtaf24",
				"source(output(",
				"          {Academic Career} as string,",
				"          {Academic Group} as string,",
				"          {Course ID} as string,",
				"          {Subject Area} as string,",
				"          {Catalog Nbr} as string,",
				"          {Class Section} as string,",
				"          Description as string,",
				"          Session as string,",
				"          {Enrollment Total} as string,",
				"          {Exam Time Code} as string,",
				"          {Exam Date} as string,",
				"          {Exam Start Time} as string,",
				"          {Exam End Time} as string,",
				"          {Facility ID(s)} as string,",
				"          {Room Capacity} as string,",
				"          {Combined Exam} as string,",
				"          {Instructor(s)} as string,",
				"          {Instructor's Email(s)} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> finalsf24",
				"source(output(",
				"          Code as string,",
				"          {Full Name} as string,",
				"          {Street Address} as string,",
				"          {Best Stop} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> bubuildingcodes",
				"historicalmbtaf24 foldDown(unroll(features),",
				"     mapColumn(",
				"          mode = features.properties.mode,",
				"          season = features.properties.season,",
				"          route_id = features.properties.route_id,",
				"          dir_id = features.properties.dir_id,",
				"          day_type_id = features.properties.day_type_id,",
				"          day_type_name = features.properties.day_type_name,",
				"          stop_name = features.properties.stop_name,",
				"          parent_station = features.properties.parent_station,",
				"          total_ons = features.properties.total_ons,",
				"          total_offs = features.properties.total_offs,",
				"          number_service_days = features.properties.number_service_days,",
				"          hour_of_service = features.properties.hour_of_service,",
				"          average_ons = features.properties.average_ons,",
				"          average_offs = features.properties.average_offs,",
				"          average_flow = features.properties.average_flow",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flatten1",
				"select1 derive(day_of_week = case(",
				"  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 1, 'Sunday',",
				"  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 2, 'Weekday',",
				"  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 3, 'Weekday',",
				"  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 4, 'Weekday',",
				"  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 5, 'Weekday',",
				"  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 6, 'Weekday',",
				"  'Saturday'",
				"),",
				"          exam_start_bucket = concat(",
				"  lpad(toString(hour(toTimestamp(exam_start_time, 'h:mm a'))), 2, '0'),",
				"  ':00:00'",
				"),",
				"          exam_end_bucket = concat(",
				"  lpad(",
				"    toString(",
				"      iif(",
				"        minute(toTimestamp(exam_end_time, 'h:mm a')) > 0,",
				"        hour(toTimestamp(exam_end_time, 'h:mm a')) + 1,",
				"        hour(toTimestamp(exam_end_time, 'h:mm a'))",
				"      )",
				"    ),",
				"    2,",
				"    '0'",
				"  ),",
				"  ':00:00'",
				")) ~> derivedColumn2",
				"finalsf24 select(mapColumn(",
				"          each(match(true()),",
				"               lower(replace(replace(replace(replace(replace(replace($$,' ','_'),'{',''),'}',''),'@','_'),'-','_'),'.','_')) = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"bubuildingcodes select(mapColumn(",
				"          each(match(true()),",
				"               lower(replace(replace(replace(replace(replace(replace($$,' ','_'),'{',''),'}',''),'@','_'),'-','_'),'.','_')) = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"derivedColumn2 select(mapColumn(",
				"          academic_career,",
				"          academic_group,",
				"          course_id,",
				"          subject_area,",
				"          catalog_nbr,",
				"          class_section,",
				"          description,",
				"          session,",
				"          enrollment_total,",
				"          exam_time_code,",
				"          exam_date,",
				"          exam_start_time,",
				"          exam_end_time,",
				"          facility_ids = {facility_id(s)},",
				"          room_capacity,",
				"          combined_exam,",
				"          instructors = {instructor(s)},",
				"          instructors_emails = {instructor's_email(s)},",
				"          day_of_week,",
				"          exam_start_bucket,",
				"          exam_end_bucket",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"flatten1 select(mapColumn(",
				"          mode,",
				"          season,",
				"          route_id,",
				"          dir_id,",
				"          day_type_id,",
				"          day_type_name,",
				"          stop_name,",
				"          parent_station,",
				"          total_ons,",
				"          total_offs,",
				"          number_service_days,",
				"          hour_of_service,",
				"          average_ons,",
				"          average_offs,",
				"          average_flow",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"select4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1",
				"select3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink2",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink3"
			]
		}
	}
}