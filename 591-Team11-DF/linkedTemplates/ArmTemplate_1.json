							"name": "select2"
						}
					],
					"scriptLines": [
						"source(output(",
						"          {Academic Career} as string,",
						"          {Academic Group} as string,",
						"          {Course ID} as string,",
						"          {Subject Area} as string,",
						"          {Catalog Nbr} as string,",
						"          {Class Section} as string,",
						"          Description as string,",
						"          Session as string,",
						"          {Enrollment Total} as string,",
						"          {Exam Time Code} as string,",
						"          {Exam Date} as string,",
						"          {Exam Start Time} as string,",
						"          {Exam End Time} as string,",
						"          {Facility ID(s)} as string,",
						"          {Room Capacity} as string,",
						"          {Combined Exam} as string,",
						"          {Instructor(s)} as string,",
						"          {Instructor's Email(s)} as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> finalss26",
						"finalss26 select(mapColumn(",
						"          each(match(true()),",
						"               lower(replace(replace(replace(replace(replace(replace($$,' ','_'),'{',''),'}',''),'@','_'),'-','_'),'.','_')) = $$)",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select1",
						"select1 derive(day_of_week = case(  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 1, 'Sunday',  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 2, 'Weekday',  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 3, 'Weekday',  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 4, 'Weekday',  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 5, 'Weekday',  dayOfWeek(toDate(exam_date, 'MM/dd/yyyy')) == 6, 'Weekday',  'Saturday'),",
						"          exam_start_bucket = concat(  lpad(toString(hour(toTimestamp(exam_start_time, 'h:mm a'))), 2, '0'),  ':00:00'),",
						"          exam_end_bucket = concat(  lpad(    toString(      iif(        minute(toTimestamp(exam_end_time, 'h:mm a')) > 0,        hour(toTimestamp(exam_end_time, 'h:mm a')) + 1,        hour(toTimestamp(exam_end_time, 'h:mm a'))      )    ),    2,    '0'  ),  ':00:00')) ~> derivedColumn1",
						"derivedColumn1 select(mapColumn(",
						"          academic_career,",
						"          academic_group,",
						"          course_id,",
						"          subject_area,",
						"          catalog_nbr,",
						"          class_section,",
						"          description,",
						"          session,",
						"          enrollment_total,",
						"          exam_time_code,",
						"          exam_date,",
						"          exam_start_time,",
						"          exam_end_time,",
						"          facility_ids = {facility_id(s)},",
						"          room_capacity,",
						"          combined_exam,",
						"          instructors = {instructor(s)},",
						"          {instructor's_emails} = {instructor's_email(s)},",
						"          day_of_week,",
						"          exam_start_bucket,",
						"          exam_end_bucket",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select2",
						"select2 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     format: 'parquet',",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
