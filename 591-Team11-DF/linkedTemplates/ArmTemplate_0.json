			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"description": "Combine Fall 2024 Ridership data with Fall 2024 class schedule ",
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "Json_Historical_MBTA",
								"type": "DatasetReference"
							},
