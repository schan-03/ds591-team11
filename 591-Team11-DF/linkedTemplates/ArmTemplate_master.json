{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "591-Team11-DF"
		},
		"LS_ADLS_MBTA_Historical_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_MBTA_Historical'"
		},
		"LS_Blob_MBTA_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_MBTA'"
		},
		"LS_ADLS_MBTA_Historical_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://591team11storage.dfs.core.windows.net/"
		},
		"LS_REST_MBTA_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://services1.arcgis.com/ceiitspzDAHrdGO1/arcgis/rest/services/"
		},
		"TRIGGER_MBTA_Ingest_1year_properties_PL_MBTA_Ingestion_parameters_item_info": {
			"type": "string",
			"defaultValue": "Fall_2024_MBTA_Rail_Ridership_by_Hour_Route_Line_and_Stop/FeatureServer/0/query?where=1%3D1&outFields=*&outSR=4326&f=json"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "591-Team11-DF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_MBTA_Historical_accountKey": {
						"value": "[parameters('LS_ADLS_MBTA_Historical_accountKey')]"
					},
					"LS_Blob_MBTA_connectionString": {
						"value": "[parameters('LS_Blob_MBTA_connectionString')]"
					},
					"LS_ADLS_MBTA_Historical_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_MBTA_Historical_properties_typeProperties_url')]"
					},
					"LS_REST_MBTA_properties_typeProperties_url": {
						"value": "[parameters('LS_REST_MBTA_properties_typeProperties_url')]"
					},
					"TRIGGER_MBTA_Ingest_1year_properties_PL_MBTA_Ingestion_parameters_item_info": {
						"value": "[parameters('TRIGGER_MBTA_Ingest_1year_properties_PL_MBTA_Ingestion_parameters_item_info')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}